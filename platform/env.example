# 复制为 .env.local（或部署平台的环境变量）— 勿提交真实值

# --- Database ---
DATABASE_URL=

# --- Object storage (e.g. Vercel Blob / S3) ---
BLOB_READ_WRITE_TOKEN=
# 或 S3:
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- Auth (示例：Clerk / Auth.js) ---
# CLERK_SECRET_KEY=
# NEXTAUTH_SECRET=

# --- Google AI (仅服务端) ---
GEMINI_API_KEY=

# --- Async jobs (示例：Inngest / QStash) ---
# INNGEST_EVENT_KEY=
# QSTASH_TOKEN=

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
